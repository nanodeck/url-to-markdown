TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
APP_URL=http://localhost:3333
APP_NAME=url-to-markdown
APP_VERSION=0.0.0
APP_ENV=development

REQUEST_BODY_LIMIT=5mb

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_DURATION=1 minute
RATE_LIMIT_BLOCK_FOR=5 minutes
LIMITER_STORE=memory

URL_TIMEOUT_MS=30000
URL_NAVIGATION_TIMEOUT_MS=30000
URL_VIEWPORT_WIDTH=1280
URL_VIEWPORT_HEIGHT=720
URL_WAIT_UNTIL=load
# URL_IGNORE_HTTPS_ERRORS=true  # Insecure: bypass TLS validation for both browser and direct fetch (use only for corp MITM proxies / dev)

# SSRF_ALLOWED_CIDRS=10.96.0.0/12,10.244.0.0/16
# SSRF_ALLOWED_HOSTS=pdf-store.internal.svc.cluster.local

# Maximum upload size for /api/file in megabytes (default: 50)
UPLOAD_MAX_SIZE_MB=50
