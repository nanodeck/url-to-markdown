TZ=UTC
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=test-key-for-running-tests-only-not-prod
NODE_ENV=test
APP_URL=http://localhost:3333
APP_NAME=url-to-markdown
APP_VERSION=0.0.0
APP_ENV=test

REQUEST_BODY_LIMIT=5mb

